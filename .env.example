# MongoDB
MONGO_URI=mongodb://admin:admin@localhost:27017
MONGO_DB=scrapy-project
MONGO_COLLECTION_LANDING=landing_metadata
MONGO_COLLECTION_TRANSFORMED=transformed_metadata

# MinIO / S3
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_REGION=us-east-1
S3_BUCKET_LANDING=landing-docs
S3_BUCKET_TRANSFORMED=transformed-docs
S3_USE_SSL=false

# Scraper behavior
SOURCE_BASE_URL=https://www.workplacerelations.ie/en/search/
SCRAPY_CONCURRENT_REQUESTS=4
SCRAPY_DOWNLOAD_DELAY=0.5
SCRAPY_RETRY_TIMES=4
PARTITION_GRANULARITY=monthly
PARTITION_STEP_DAYS=30
USER_AGENTS=Mozilla/5.0 (Windows NT 10.0; Win64; x64),Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7),Mozilla/5.0 (X11; Linux x86_64)

# Logging
LOG_LEVEL=INFO

# Dagster (MUST be an absolute path)
DAGSTER_HOME=/absolute/path/to/project/.dagster
